# Pick ONE provider and fill in your key.
# DeepSeek (cheapest, recommended)
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=deepseek-chat       # optional override

# Zhipu (智谱 GLM)
# LLM_PROVIDER=zhipu
# LLM_API_KEY=xxx.xxx
# LLM_MODEL=glm-4-flash

# Kimi (Moonshot)
# LLM_PROVIDER=kimi
# LLM_API_KEY=sk-xxx
# LLM_MODEL=moonshot-v1-8k

# OpenAI (or any OpenAI-compatible endpoint via LLM_BASE_URL)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
